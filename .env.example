# Environment Configuration for PILT Backend

# ===== API Configuration =====
# PILT Backend API URL
# For local development on a real device: http://<YOUR_LAN_IP>:8000
# Example: http://192.168.100.5:8000
# For production: https://your-production-backend-url.com
EXPO_PUBLIC_API_URL=http://192.168.100.5:8000

# ===== OAuth - Google =====
# Get these from https://console.cloud.google.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ===== OAuth - GitHub =====
# Get these from https://github.com/settings/developers
EXPO_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id

# ===== Feature Flags =====
# Enable biometric authentication (Face ID / Fingerprint)
EXPO_PUBLIC_ENABLE_BIOMETRIC=true

# Enable push notifications
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

# ===== Analytics =====
# Your analytics service API key
EXPO_PUBLIC_ANALYTICS_KEY=your-analytics-key-here
